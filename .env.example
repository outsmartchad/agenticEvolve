# agenticEvolve v2 — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Telegram ─────────────────────────────────────────────────
# Get a token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your chat ID (for cron job delivery). Get it from @userinfobot
TELEGRAM_CHAT_ID=

# ── Discord ──────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
# Channel ID for cron job delivery
DISCORD_HOME_CHANNEL=
