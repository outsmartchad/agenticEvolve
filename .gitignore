# Runtime data (not tracked — generated per-machine)
logs/*.log
signals/
skills-queue/
archive/

# Keep directory structure
!logs/.gitkeep
!signals/.gitkeep
!skills-queue/.gitkeep
!archive/.gitkeep

# v2 runtime data
memory/sessions.db
memory/sessions.db-wal
memory/sessions.db-shm
cron/output/
gateway.pid

# node_modules (all subdirs)
node_modules/
whatsapp-bridge/node_modules/
browser/node_modules/

# WhatsApp bridge runtime
whatsapp-bridge/auth/

# Browser profiles (runtime, large binaries)
browser-profiles/

# Session handoff files (runtime)
sessions/

# OS
.DS_Store

# Secrets (never commit)
.env
.discord-token
*.key
config.yaml
__pycache__/
dashboard/node_modules/
dashboard/.next/
