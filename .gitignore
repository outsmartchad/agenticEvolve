# Runtime data (not tracked — generated per-machine)
logs/*.log
signals/
skills-queue/
archive/

# Keep directory structure
!logs/.gitkeep
!signals/.gitkeep
!skills-queue/.gitkeep
!archive/.gitkeep

# v2 runtime data
memory/sessions.db
memory/sessions.db-wal
memory/sessions.db-shm
cron/output/
gateway.pid

# WhatsApp bridge runtime
whatsapp-bridge/node_modules/
whatsapp-bridge/auth/

# OS
.DS_Store

# Secrets (never commit)
.env
*.key
config.yaml
__pycache__/
